        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<style>\n  .gk-faq {\n    --gk-red:#E10600;\n    --gk-dark:#080808;\n    --gk-bg:#FFFFFF;\n    --gk-text:#1A1A1A;\n    background:var(--gk-bg);\n    padding:72px 20px;\n    font-family:'Inter','Helvetica Neue',Arial,sans-serif;\n  }\n  .gk-faq__wrap{max-width:820px;margin:0 auto;}\n  .gk-faq__head{text-align:center;margin-bottom:48px;}\n  .gk-faq__eyebrow{display:inline-block;font-size:13px;font-weight:800;letter-spacing:.18em;text-transform:uppercase;color:var(--gk-red);margin-bottom:14px;}\n  .gk-faq__eyebrow::before,.gk-faq__eyebrow::after{content:\"\";display:inline-block;width:26px;height:2px;background:var(--gk-red);vertical-align:middle;margin:0 10px;}\n  .gk-faq__title{font-size:clamp(30px,6vw,46px);font-weight:900;line-height:1.05;color:var(--gk-dark);margin:0 0 12px;text-transform:uppercase;letter-spacing:-.01em;}\n  .gk-faq__subtitle{font-size:16px;color:var(--gk-text);opacity:.7;max-width:520px;margin:0 auto;line-height:1.6;}\n  .gk-faq__item{border:2px solid #ECECEC;border-radius:14px;margin-bottom:14px;overflow:hidden;background:#fff;transition:border-color .25s,box-shadow .25s;}\n  .gk-faq__item[open]{border-color:var(--gk-red);box-shadow:0 8px 30px rgba(225,6,0,.08);}\n  .gk-faq__q{list-style:none;cursor:pointer;display:flex;align-items:center;gap:16px;padding:22px 24px;font-size:17px;font-weight:700;color:var(--gk-dark);transition:color .2s;}\n  .gk-faq__q::-webkit-details-marker{display:none;}\n  .gk-faq__item[open] .gk-faq__q{color:var(--gk-red);}\n  .gk-faq__num{flex:0 0 auto;font-size:13px;font-weight:900;color:#fff;background:var(--gk-dark);min-width:30px;height:30px;display:grid;place-items:center;border-radius:8px;transition:background .2s;}\n  .gk-faq__item[open] .gk-faq__num{background:var(--gk-red);}\n  .gk-faq__icon{flex:0 0 auto;margin-left:auto;width:22px;height:22px;position:relative;}\n  .gk-faq__icon::before,.gk-faq__icon::after{content:\"\";position:absolute;top:50%;left:50%;width:14px;height:2.5px;border-radius:2px;background:var(--gk-dark);transform:translate(-50%,-50%);transition:transform .3s,background .2s;}\n  .gk-faq__icon::after{transform:translate(-50%,-50%) rotate(90deg);}\n  .gk-faq__item[open] .gk-faq__icon::before,.gk-faq__item[open] .gk-faq__icon::after{background:var(--gk-red);}\n  .gk-faq__item[open] .gk-faq__icon::after{transform:translate(-50%,-50%) rotate(0);}\n  .gk-faq__a{padding:0 24px 24px 70px;font-size:15.5px;line-height:1.7;color:var(--gk-text);opacity:.85;}\n  .gk-faq__a a{color:var(--gk-red);font-weight:600;}\n  .gk-faq__cta{margin-top:48px;background:var(--gk-dark);border-radius:18px;padding:40px 32px;text-align:center;color:#fff;}\n  .gk-faq__cta h3{font-size:24px;font-weight:900;margin:0 0 8px;text-transform:uppercase;}\n  .gk-faq__cta p{margin:0 0 22px;opacity:.7;font-size:15px;}\n  .gk-faq__btn{display:inline-block;background:var(--gk-red);color:#fff;text-decoration:none;font-weight:800;font-size:15px;text-transform:uppercase;letter-spacing:.04em;padding:15px 38px;border-radius:50px;transition:transform .2s,filter .2s;}\n  .gk-faq__btn:hover{transform:translateY(-2px);filter:brightness(1.1);}\n  @media(max-width:600px){.gk-faq__a{padding-left:24px;}.gk-faq__q{padding:18px 18px;font-size:15.5px;}}\n</style>\n\n<section class=\"gk-faq\">\n  <div class=\"gk-faq__wrap\">\n\n    <div class=\"gk-faq__head\">\n      <span class=\"gk-faq__eyebrow\">Besoin d'aide ?</span>\n      <h2 class=\"gk-faq__title\">Questions Fréquentes</h2>\n      <p class=\"gk-faq__subtitle\">Tout ce que tu dois savoir avant de commander ton maillot. Une autre question ? Contacte-nous, on répond vite.</p>\n    </div>\n\n    <details class=\"gk-faq__item\">\n      <summary class=\"gk-faq__q\"><span class=\"gk-faq__num\">01</span><span>Quels sont les délais de livraison ?</span><span class=\"gk-faq__icon\"></span></summary>\n      <div class=\"gk-faq__a\">Nos maillots sont expédiés sous 24 à 48h. Comptez ensuite entre 7 et 14 jours ouvrés pour la réception en France métropolitaine. Un numéro de suivi vous est envoyé par e-mail dès l'expédition.</div>\n    </details>\n\n    <details class=\"gk-faq__item\">\n      <summary class=\"gk-faq__q\"><span class=\"gk-faq__num\">02</span><span>Comment suivre ma commande ?</span><span class=\"gk-faq__icon\"></span></summary>\n      <div class=\"gk-faq__a\">Dès que votre colis part, vous recevez un lien de suivi par e-mail. Vous pouvez aussi suivre votre maillot à tout moment depuis la page <a href=\"/apps/parcelpanel\">Suivi du Maillot</a>.</div>\n    </details>\n\n    <details class=\"gk-faq__item\">\n      <summary class=\"gk-faq__q\"><span class=\"gk-faq__num\">03</span><span>Quelle est la qualité des maillots ?</span><span class=\"gk-faq__icon\"></span></summary>\n      <div class=\"gk-faq__a\">Tous nos maillots sont de qualité supérieure (finitions, flocages et logos thermocollés haut de gamme), conçus en tissu respirant et confortable, idéal pour le sport comme pour le quotidien.</div>\n    </details>\n\n    <details class=\"gk-faq__item\">\n      <summary class=\"gk-faq__q\"><span class=\"gk-faq__num\">04</span><span>Comment choisir ma taille ?</span><span class=\"gk-faq__icon\"></span></summary>\n      <div class=\"gk-faq__a\">Nos maillots taillent normalement (du S au XXL). Si vous hésitez entre deux tailles, on vous conseille de prendre la taille au-dessus. Un guide des tailles détaillé est disponible sur chaque fiche produit.</div>\n    </details>\n\n    <details class=\"gk-faq__item\">\n      <summary class=\"gk-faq__q\"><span class=\"gk-faq__num\">05</span><span>Puis-je personnaliser mon maillot (nom + numéro) ?</span><span class=\"gk-faq__icon\"></span></summary>\n      <div class=\"gk-faq__a\">Oui ! Sur les produits éligibles, vous pouvez ajouter le flocage de votre choix (nom et numéro) directement depuis la fiche produit avant l'ajout au panier.</div>\n    </details>\n\n    <details class=\"gk-faq__item\">\n      <summary class=\"gk-faq__q\"><span class=\"gk-faq__num\">06</span><span>Quels sont les modes de paiement acceptés ?</span><span class=\"gk-faq__icon\"></span></summary>\n      <div class=\"gk-faq__a\">Nous acceptons les cartes Visa, Mastercard, American Express, ainsi qu'Apple Pay et Google Pay. Tous les paiements sont 100% sécurisés et cryptés.</div>\n    </details>\n\n    <details class=\"gk-faq__item\">\n      <summary class=\"gk-faq__q\"><span class=\"gk-faq__num\">07</span><span>Puis-je échanger ou me faire rembourser ?</span><span class=\"gk-faq__icon\"></span></summary>\n      <div class=\"gk-faq__a\">Vous disposez de 14 jours après réception pour demander un échange ou un remboursement, à condition que le maillot soit neuf et non porté. Contactez-nous et on s'occupe du reste.</div>\n    </details>\n\n    <details class=\"gk-faq__item\">\n      <summary class=\"gk-faq__q\"><span class=\"gk-faq__num\">08</span><span>Comment vous contacter ?</span><span class=\"gk-faq__icon\"></span></summary>\n      <div class=\"gk-faq__a\">Une question ? Écrivez-nous via la page <a href=\"/pages/contact\">Contact</a> ou en message privé sur nos réseaux. On répond sous 24h.</div>\n    </details>\n\n    <div class=\"gk-faq__cta\">\n      <h3>Toujours une question ?</h3>\n      <p>Notre équipe te répond sous 24h, du lundi au samedi.</p>\n      <a href=\"/pages/contact\" class=\"gk-faq__btn\">Nous contacter</a>\n    </div>\n\n  </div>\n</section>",
