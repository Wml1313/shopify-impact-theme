    "custom_liquid_cKhjeB": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "{% comment %}\n  ============================================================\n  GOALKORNER — Page CONTACT\n  ------------------------------------------------------------\n  À coller dans un bloc \"Liquid personnalisé\" OU dans un\n  template page.contact. Utilise le vrai formulaire Shopify\n  {% form 'contact' %} : les messages arrivent sur l'email\n  de la boutique (Paramètres > Détails > E-mail du compte).\n  DA : Noir #080808 · Rouge #E10600 · Blanc\n  ============================================================\n{% endcomment %}\n\n<style>\n  .gk-c{\n    --red:#E10600; --dark:#080808; --bg:#FFFFFF; --text:#1A1A1A;\n    --line:#ECECEC; --soft:#F6F6F6;\n    background:var(--bg); color:var(--text);\n    font-family:'Inter','Helvetica Neue',Arial,sans-serif;\n    padding:64px 20px 80px;\n  }\n  .gk-c *{box-sizing:border-box;}\n  .gk-c__wrap{max-width:1080px;margin:0 auto;}\n\n  /* HERO */\n  .gk-c__hero{text-align:center;margin-bottom:54px;}\n  .gk-c__eyebrow{display:inline-block;font-size:13px;font-weight:800;letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:14px;}\n  .gk-c__eyebrow::before,.gk-c__eyebrow::after{content:\"\";display:inline-block;width:26px;height:2px;background:var(--red);vertical-align:middle;margin:0 10px;}\n  .gk-c__title{font-size:clamp(32px,6.5vw,52px);font-weight:900;line-height:1.04;color:var(--dark);margin:0 0 14px;text-transform:uppercase;letter-spacing:-.01em;}\n  .gk-c__title em{color:var(--red);font-style:normal;}\n  .gk-c__sub{font-size:16px;color:var(--text);opacity:.7;max-width:540px;margin:0 auto;line-height:1.6;}\n\n  /* GRID */\n  .gk-c__grid{display:grid;grid-template-columns:0.85fr 1.15fr;gap:28px;align-items:start;}\n  @media(max-width:860px){.gk-c__grid{grid-template-columns:1fr;}}\n\n  /* PANNEAU INFOS (sombre) */\n  .gk-c__panel{background:var(--dark);color:#fff;border-radius:20px;padding:36px 32px;position:relative;overflow:hidden;}\n  .gk-c__panel::after{content:\"\";position:absolute;top:-40px;right:-40px;width:160px;height:160px;background:var(--red);border-radius:50%;filter:blur(60px);opacity:.35;}\n  .gk-c__panel-h{font-size:13px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:var(--red);margin:0 0 26px;position:relative;}\n  .gk-c__info{display:flex;gap:14px;margin-bottom:24px;position:relative;}\n  .gk-c__ico{flex:0 0 auto;width:42px;height:42px;border-radius:11px;background:rgba(255,255,255,.08);display:grid;place-items:center;font-size:19px;}\n  .gk-c__info-l{font-size:12px;text-transform:uppercase;letter-spacing:.08em;opacity:.55;margin-bottom:3px;}\n  .gk-c__info-v{font-size:15px;font-weight:600;line-height:1.5;}\n  .gk-c__info-v a{color:#fff;text-decoration:none;border-bottom:1px solid var(--red);}\n  .gk-c__hours{position:relative;border-top:1px solid rgba(255,255,255,.1);margin-top:6px;padding-top:22px;}\n  .gk-c__hours-row{display:flex;justify-content:space-between;font-size:14px;padding:5px 0;}\n  .gk-c__hours-row span:first-child{opacity:.6;}\n  .gk-c__hours-row span:last-child{font-weight:600;}\n  .gk-c__social{position:relative;display:flex;gap:12px;margin-top:26px;}\n  .gk-c__social a{flex:1;text-align:center;padding:12px;border-radius:11px;background:rgba(255,255,255,.07);color:#fff;text-decoration:none;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:.05em;transition:background .2s;}\n  .gk-c__social a:hover{background:var(--red);}\n\n  /* FORMULAIRE */\n  .gk-c__form-wrap{background:#fff;border:2px solid var(--line);border-radius:20px;padding:34px 32px;}\n  .gk-c__form-h{font-size:22px;font-weight:900;text-transform:uppercase;color:var(--dark);margin:0 0 6px;}\n  .gk-c__form-d{font-size:14px;opacity:.6;margin:0 0 22px;}\n\n  .gk-c__chips{display:flex;flex-wrap:wrap;gap:9px;margin-bottom:24px;}\n  .gk-c__chip{cursor:pointer;}\n  .gk-c__chip input{position:absolute;opacity:0;pointer-events:none;}\n  .gk-c__chip span{display:inline-block;padding:9px 15px;border:2px solid var(--line);border-radius:50px;font-size:13.5px;font-weight:700;color:var(--text);transition:all .18s;}\n  .gk-c__chip input:checked + span{background:var(--red);border-color:var(--red);color:#fff;}\n\n  .gk-c__row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}\n  @media(max-width:520px){.gk-c__row{grid-template-columns:1fr;}}\n  .gk-c__field{margin-bottom:16px;}\n  .gk-c__label{display:block;font-size:12.5px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--dark);margin-bottom:7px;}\n  .gk-c__label i{color:var(--red);font-style:normal;}\n  .gk-c__input,.gk-c__textarea{width:100%;border:2px solid var(--line);border-radius:12px;padding:13px 15px;font-size:15px;font-family:inherit;color:var(--text);background:var(--soft);transition:border-color .18s,background .18s;}\n  .gk-c__input:focus,.gk-c__textarea:focus{outline:none;border-color:var(--red);background:#fff;}\n  .gk-c__textarea{resize:vertical;min-height:130px;}\n  .gk-c__count{text-align:right;font-size:12px;opacity:.5;margin-top:5px;}\n\n  .gk-c__stars{display:flex;gap:6px;margin-top:4px;}\n  .gk-c__star{font-size:26px;color:var(--line);cursor:pointer;transition:color .15s,transform .15s;line-height:1;}\n  .gk-c__star:hover{transform:scale(1.15);}\n  .gk-c__star.on{color:var(--red);}\n\n  .gk-c__btn{width:100%;margin-top:8px;background:var(--red);color:#fff;border:none;cursor:pointer;font-family:inherit;font-weight:800;font-size:15px;text-transform:uppercase;letter-spacing:.04em;padding:16px;border-radius:50px;transition:transform .2s,filter .2s;}\n  .gk-c__btn:hover{transform:translateY(-2px);filter:brightness(1.1);}\n  .gk-c__guarantee{text-align:center;font-size:12.5px;opacity:.55;margin-top:14px;}\n\n  /* SUCCÈS */\n  .gk-c__success{background:#fff;border:2px solid var(--red);border-radius:20px;padding:46px 32px;text-align:center;}\n  .gk-c__success-ico{width:64px;height:64px;border-radius:50%;background:var(--red);color:#fff;font-size:30px;display:grid;place-items:center;margin:0 auto 20px;}\n  .gk-c__success h3{font-size:24px;font-weight:900;text-transform:uppercase;color:var(--dark);margin:0 0 10px;}\n  .gk-c__success p{font-size:15px;opacity:.7;margin:0 auto;max-width:380px;line-height:1.6;}\n\n  /* FAQ */\n  .gk-c__faq{max-width:820px;margin:64px auto 0;}\n  .gk-c__faq-t{text-align:center;font-size:clamp(24px,5vw,34px);font-weight:900;text-transform:uppercase;color:var(--dark);margin:0 0 34px;}\n  .gk-c__faq-t em{color:var(--red);font-style:normal;}\n  .gk-c__item{border:2px solid var(--line);border-radius:14px;margin-bottom:13px;background:#fff;overflow:hidden;transition:border-color .25s,box-shadow .25s;}\n  .gk-c__item[open]{border-color:var(--red);box-shadow:0 8px 30px rgba(225,6,0,.07);}\n  .gk-c__q{list-style:none;cursor:pointer;display:flex;align-items:center;gap:14px;padding:20px 22px;font-size:16px;font-weight:700;color:var(--dark);}\n  .gk-c__q::-webkit-details-marker{display:none;}\n  .gk-c__item[open] .gk-c__q{color:var(--red);}\n  .gk-c__plus{margin-left:auto;width:20px;height:20px;position:relative;flex:0 0 auto;}\n  .gk-c__plus::before,.gk-c__plus::after{content:\"\";position:absolute;top:50%;left:50%;width:13px;height:2.5px;border-radius:2px;background:var(--dark);transform:translate(-50%,-50%);transition:transform .3s,background .2s;}\n  .gk-c__plus::after{transform:translate(-50%,-50%) rotate(90deg);}\n  .gk-c__item[open] .gk-c__plus::before,.gk-c__item[open] .gk-c__plus::after{background:var(--red);}\n  .gk-c__item[open] .gk-c__plus::after{transform:translate(-50%,-50%) rotate(0);}\n  .gk-c__a{padding:0 22px 22px;font-size:15px;line-height:1.7;opacity:.85;}\n</style>\n\n<section class=\"gk-c\">\n  <div class=\"gk-c__wrap\">\n\n    <!-- HERO -->\n    <div class=\"gk-c__hero\">\n      <span class=\"gk-c__eyebrow\">On est là pour toi</span>\n      <h1 class=\"gk-c__title\">Contacte <em>GoalKorner</em></h1>\n      <p class=\"gk-c__sub\">Une question, un problème avec ta commande, une idée de collab ? Notre équipe te répond sous 24h.</p>\n    </div>\n\n    <div class=\"gk-c__grid\">\n\n      <!-- PANNEAU INFOS -->\n      <aside class=\"gk-c__panel\">\n        <p class=\"gk-c__panel-h\">Nos coordonnées</p>\n\n        <div class=\"gk-c__info\">\n          <div class=\"gk-c__ico\">✉️</div>\n          <div>\n            <div class=\"gk-c__info-l\">Email</div>\n            <div class=\"gk-c__info-v\"><a href=\"mailto:contact@goalkorner.store\">contact@goalkorner.store</a></div>\n          </div>\n        </div>\n\n        <div class=\"gk-c__info\">\n          <div class=\"gk-c__ico\">📍</div>\n          <div>\n            <div class=\"gk-c__info-l\">Localisation</div>\n            <div class=\"gk-c__info-v\">France · Livraison internationale disponible</div>\n          </div>\n        </div>\n\n        <div class=\"gk-c__info\">\n          <div class=\"gk-c__ico\">⚡</div>\n          <div>\n            <div class=\"gk-c__info-l\">Temps de réponse</div>\n            <div class=\"gk-c__info-v\">Moins de 24h en moyenne · Prioritaire pour les commandes</div>\n          </div>\n        </div>\n\n        <div class=\"gk-c__hours\">\n          <div class=\"gk-c__hours-row\"><span>Lundi — Vendredi</span><span>09h — 20h</span></div>\n          <div class=\"gk-c__hours-row\"><span>Samedi</span><span>10h — 18h</span></div>\n          <div class=\"gk-c__hours-row\"><span>Dimanche</span><span>Réponse différée</span></div>\n        </div>\n\n        <div class=\"gk-c__social\">\n          <a href=\"https://www.instagram.com/\" target=\"_blank\" rel=\"noopener\">Instagram</a>\n          <a href=\"https://www.tiktok.com/\" target=\"_blank\" rel=\"noopener\">TikTok</a>\n        </div>\n      </aside>\n\n      <!-- FORMULAIRE -->\n      <div>\n      {% form 'contact', id: 'gk-contact-form' %}\n\n        {% if form.posted_successfully? %}\n          <div class=\"gk-c__success\">\n            <div class=\"gk-c__success-ico\">✓</div>\n            <h3>Message envoyé !</h3>\n            <p>Merci ! On a bien reçu ton message et on te répond dans les 24h par email.</p>\n          </div>\n        {% else %}\n\n          <div class=\"gk-c__form-wrap\">\n            <h2 class=\"gk-c__form-h\">Envoie-nous un message</h2>\n            <p class=\"gk-c__form-d\">Sélectionne le sujet qui correspond à ta demande pour une réponse plus rapide.</p>\n\n            {% if form.errors %}\n              <p style=\"background:#FDECEC;border:1px solid var(--red);color:var(--red);padding:12px 14px;border-radius:10px;font-size:14px;margin-bottom:18px;\">\n                Oups, vérifie les champs obligatoires (nom, email valide et message).\n              </p>\n            {% endif %}\n\n            <!-- SUJETS -->\n            <div class=\"gk-c__chips\">\n              <label class=\"gk-c__chip\"><input type=\"radio\" name=\"contact[Sujet]\" value=\"📦 Commande\" checked><span>📦 Commande</span></label>\n              <label class=\"gk-c__chip\"><input type=\"radio\" name=\"contact[Sujet]\" value=\"🚚 Livraison\"><span>🚚 Livraison</span></label>\n              <label class=\"gk-c__chip\"><input type=\"radio\" name=\"contact[Sujet]\" value=\"↩️ Retour\"><span>↩️ Retour</span></label>\n              <label class=\"gk-c__chip\"><input type=\"radio\" name=\"contact[Sujet]\" value=\"⚠️ Défectueux\"><span>⚠️ Défectueux</span></label>\n              <label class=\"gk-c__chip\"><input type=\"radio\" name=\"contact[Sujet]\" value=\"🤝 Partenariat\"><span>🤝 Partenariat</span></label>\n              <label class=\"gk-c__chip\"><input type=\"radio\" name=\"contact[Sujet]\" value=\"💬 Autre\"><span>💬 Autre</span></label>\n            </div>\n\n            <!-- NOM COMPLET (caché, rempli par JS) -->\n            <input type=\"hidden\" name=\"contact[name]\" id=\"gk-fullname\">\n\n            <div class=\"gk-c__row\">\n              <div class=\"gk-c__field\">\n                <label class=\"gk-c__label\">Prénom <i>*</i></label>\n                <input class=\"gk-c__input\" type=\"text\" id=\"gk-first\" required>\n              </div>\n              <div class=\"gk-c__field\">\n                <label class=\"gk-c__label\">Nom <i>*</i></label>\n                <input class=\"gk-c__input\" type=\"text\" id=\"gk-last\" required>\n              </div>\n            </div>\n\n            <div class=\"gk-c__row\">\n              <div class=\"gk-c__field\">\n                <label class=\"gk-c__label\">Email <i>*</i></label>\n                <input class=\"gk-c__input\" type=\"email\" name=\"contact[email]\" required>\n              </div>\n              <div class=\"gk-c__field\">\n                <label class=\"gk-c__label\">Numéro de commande</label>\n                <input class=\"gk-c__input\" type=\"text\" name=\"contact[Numéro de commande]\" placeholder=\"#1234\">\n              </div>\n            </div>\n\n            <div class=\"gk-c__field\">\n              <label class=\"gk-c__label\">Message <i>*</i></label>\n              <textarea class=\"gk-c__textarea\" name=\"contact[body]\" id=\"gk-msg\" maxlength=\"1000\" required placeholder=\"Décris ta demande...\"></textarea>\n              <div class=\"gk-c__count\"><span id=\"gk-count\">0</span>/1000</div>\n            </div>\n\n            <div class=\"gk-c__field\">\n              <label class=\"gk-c__label\">Évaluation de ton expérience (optionnel)</label>\n              <input type=\"hidden\" name=\"contact[Note]\" id=\"gk-note\" value=\"\">\n              <div class=\"gk-c__stars\" id=\"gk-stars\">\n                <span class=\"gk-c__star\" data-v=\"1\">★</span>\n                <span class=\"gk-c__star\" data-v=\"2\">★</span>\n                <span class=\"gk-c__star\" data-v=\"3\">★</span>\n                <span class=\"gk-c__star\" data-v=\"4\">★</span>\n                <span class=\"gk-c__star\" data-v=\"5\">★</span>\n              </div>\n            </div>\n\n            <button type=\"submit\" class=\"gk-c__btn\">Envoyer le message →</button>\n            <p class=\"gk-c__guarantee\">Réponse garantie sous 24h · contact@goalkorner.store</p>\n          </div>\n\n        {% endif %}\n\n      {% endform %}\n      </div>\n\n    </div>\n\n    <!-- FAQ -->\n    <div class=\"gk-c__faq\">\n      <h2 class=\"gk-c__faq-t\">Questions <em>fréquentes</em></h2>\n\n      <details class=\"gk-c__item\">\n        <summary class=\"gk-c__q\">Quel est le délai de livraison ?<span class=\"gk-c__plus\"></span></summary>\n        <div class=\"gk-c__a\">Les commandes sont expédiées sous 24 à 48h. La livraison prend ensuite 7 à 14 jours ouvrés en France métropolitaine. Tu reçois un numéro de suivi par email dès l'expédition.</div>\n      </details>\n\n      <details class=\"gk-c__item\">\n        <summary class=\"gk-c__q\">Comment suivre ma commande ?<span class=\"gk-c__plus\"></span></summary>\n        <div class=\"gk-c__a\">Un email avec ton numéro de suivi est envoyé dès l'expédition. Tu peux aussi suivre ton maillot via la page <a href=\"/apps/parcelpanel\">Suivi du Maillot</a>.</div>\n      </details>\n\n      <details class=\"gk-c__item\">\n        <summary class=\"gk-c__q\">Puis-je retourner un maillot ?<span class=\"gk-c__plus\"></span></summary>\n        <div class=\"gk-c__a\">Oui, tu as 14 jours après réception pour retourner un maillot neuf et non porté. Les frais de retour sont à ta charge sauf en cas de produit défectueux.</div>\n      </details>\n\n      <details class=\"gk-c__item\">\n        <summary class=\"gk-c__q\">Mon colis est perdu, que faire ?<span class=\"gk-c__plus\"></span></summary>\n        <div class=\"gk-c__a\">Contacte-nous avec ton numéro de commande. Si le colis est confirmé perdu par le transporteur, on procède au réenvoi ou au remboursement complet sous 48h.</div>\n      </details>\n\n      <details class=\"gk-c__item\">\n        <summary class=\"gk-c__q\">Proposez-vous le flocage nom + numéro ?<span class=\"gk-c__plus\"></span></summary>\n        <div class=\"gk-c__a\">Oui, sur les produits éligibles tu peux ajouter le flocage de ton choix directement depuis la fiche produit avant l'ajout au panier.</div>\n      </details>\n    </div>\n\n  </div>\n</section>\n\n<script>\n  (function(){\n    var form = document.getElementById('gk-contact-form');\n    if(!form) return;\n\n    // Compteur de caractères\n    var msg = document.getElementById('gk-msg');\n    var count = document.getElementById('gk-count');\n    if(msg && count){ msg.addEventListener('input', function(){ count.textContent = msg.value.length; }); }\n\n    // Note étoiles\n    var note = document.getElementById('gk-note');\n    var stars = document.querySelectorAll('#gk-stars .gk-c__star');\n    function paint(v){ stars.forEach(function(s){ s.classList.toggle('on', parseInt(s.dataset.v) <= v); }); }\n    stars.forEach(function(s){\n      s.addEventListener('mouseenter', function(){ paint(parseInt(s.dataset.v)); });\n      s.addEventListener('click', function(){ note.value = s.dataset.v; paint(parseInt(s.dataset.v)); });\n    });\n    var starsWrap = document.getElementById('gk-stars');\n    if(starsWrap){ starsWrap.addEventListener('mouseleave', function(){ paint(parseInt(note.value)||0); }); }\n\n    // Fusion Prénom + Nom -> contact[name]\n    form.addEventListener('submit', function(){\n      var f = document.getElementById('gk-first');\n      var l = document.getElementById('gk-last');\n      var full = document.getElementById('gk-fullname');\n      if(f && l && full){ full.value = (f.value + ' ' + l.value).trim(); }\n    });\n  })();\n</script>",
        "background": "",
        "background_gradient": "",
        "text_color": ""
      }
    }
  },
